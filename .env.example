# URL de conexão com o PostgreSQL
# Ao rodar via Docker Compose, o host "db" é o nome do serviço do banco.
DATABASE_URL="postgresql://saas:saas@db:5432/saas?schema=public"

# Usados pelo docker-compose.yml para criar o banco no container do Postgres
POSTGRES_USER=saas
POSTGRES_PASSWORD=saas
POSTGRES_DB=saas

# Segredo usado pelo NextAuth para assinar sessões — gere um valor único em produção,
# por exemplo com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-este-valor-por-um-segredo-aleatorio"
NEXTAUTH_URL="http://localhost:3000"
